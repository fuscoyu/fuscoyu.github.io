        <mxCell id="tailscale-edge" edge="1" parent="1" source="proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2da44e;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#116329;" target="remote-subnet" value="tailscale0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="return-edge" edge="1" parent="1" source="remote-subnet" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8c959f;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;dashPattern=6 6;fontSize=12;fontColor=#57606a;" target="proxy" value="回包只回到 proxy">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="655" y="305" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fontColor=#24292f;" value="A -&amp;gt; proxy -&amp;gt; tailscale0 -&amp;gt; 远端网段" vertex="1">
          <mxGeometry height="32" width="590" x="245" y="42" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f6f8fa;strokeColor=#d0d7de;arcSize=8;fontSize=13;fontColor=#57606a;" value="NAT 网关模式：远端只看到 proxy 的 Tailscale IP，不需要知道 VPC 内每台 VM 的回程路由。" vertex="1">
          <mxGeometry height="36" width="790" x="145" y="415" as="geometry" />
        </mxCell>
